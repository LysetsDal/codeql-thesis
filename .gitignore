# --- CodeQL Databases ---
# Ignores the folder and everything inside
databases/
/_codeql_database/
# In case you create temp dbs during CLI testing
codeql-db-*/

# --- CodeQL Compilation ---
# These are the binary versions of your .ql files
*.qlx
*.qlo
# The local cache for query packs
.codeql/

# --- C# / .NET ---
bin/
obj/
*.suo
*.user

# --- IDEs ---
# We ignore the folder but keep essential VS Code configs if you share them
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/extensions.json

# Rider / JetBrains
.idea/
.rider/
*.sln.iml

# --- OS Specific ---
.DS_Store